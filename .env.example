# Google Gemini – Dialog-Erstellung, Übersetzung, Birkenbihl, Bilder
# https://aistudio.google.com/apikey (eigenen Key „zebla“ anlegen)
GEMINI_API_KEY=

# Optional: Modelle überschreiben
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# (Imagen-Modelle nur mit kostenpflichtigem Google-AI-Konto, z. B. imagen-4.0-fast-generate-001)

# Firebase Admin (Server / Vercel – geheim halten!)
# Wird auch für Cloud-Sprachausgabe (Google Text-to-Speech) genutzt.
# API im Google-Projekt aktivieren: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
FIREBASE_PROJECT_ID=dein-projekt-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@dein-projekt-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Client (Frontend – in Vercel als VITE_* setzen)
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=dein-projekt-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=dein-projekt-id
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
