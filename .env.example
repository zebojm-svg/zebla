# OpenAI – Dialog-Erstellung, Übersetzung, Birkenbihl, Bilder
OPENAI_API_KEY=sk-...

# Firebase Admin (Server / Vercel – geheim halten!)
FIREBASE_PROJECT_ID=dein-projekt-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@dein-projekt-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Client (Frontend – in Vercel als VITE_* setzen)
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=dein-projekt-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=dein-projekt-id
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
